{
  "name": "@pandacss/plugin-svelte",
  "version": "1.10.0",
  "description": "Panda CSS plugin for Svelte single file component support",
  "author": "Segun Adebayo <joseshegs@gmail.com>",
  "license": "MIT",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "homepage": "https://panda-css.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chakra-ui/panda.git",
    "directory": "packages/plugin-svelte"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format=esm --dts",
    "build-fast": "tsup src/index.ts --format=esm --no-dts",
    "dev": "pnpm build-fast --watch"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@pandacss/types": "workspace:*",
    "magic-string": "0.30.21"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  }
}
