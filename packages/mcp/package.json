{
  "name": "@pandacss/mcp",
  "version": "2.0.0-beta.2",
  "description": "MCP server for Panda CSS AI assistants",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "panda-mcp": "bin.js"
  },
  "author": "Segun Adebayo <joseshegs@gmail.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format=esm,cjs",
    "build:fast": "tsup src/index.ts src/cli.ts --format=esm,cjs",
    "dev": "pnpm build:fast --watch"
  },
  "sideEffects": false,
  "homepage": "https://panda-css.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chakra-ui/panda.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pandacss/compiler": "workspace:*",
    "citty": "0.1.6",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
