{
  "name": "@pandacss/driver-wasm",
  "version": "0.0.0",
  "description": "Browser host orchestrator that drives the wasm Panda compiler over an in-memory filesystem",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "author": "Segun Adebayo <joseshegs@gmail.com>",
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://panda-css.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chakra-ui/panda.git",
    "directory": "packages/driver-wasm"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup --dts",
    "build-fast": "tsup --no-dts",
    "dev": "pnpm build-fast --watch",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@pandacss/compiler-shared": "workspace:*",
    "@pandacss/compiler-wasm": "workspace:*",
    "@pandacss/types": "workspace:*"
  },
  "devDependencies": {
    "@pandacss/config-loader": "workspace:*"
  }
}
