{
  "name": "sandbox-cli",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cli": "pnpm codegen && pnpm cssgen && concurrently \"pnpm cssgen:watch\" \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "inspect": "node ../../packages/cli/bin.js inspect --cwd . --json",
    "codegen": "pnpm clean && node ../../packages/cli/bin.js codegen --cwd .",
    "codegen:watch": "node ../../packages/cli/bin.js codegen --cwd . --watch",
    "cssgen": "node ../../packages/cli/bin.js cssgen --cwd .",
    "cssgen:watch": "node ../../packages/cli/bin.js cssgen --cwd . --watch",
    "buildinfo": "node ../../packages/cli/bin.js buildinfo --cwd .",
    "clean": "rm -rf styled-system",
    "v1:codegen": "npx -y @pandacss/dev@latest codegen --cwd . --silent",
    "v1:cssgen": "npx -y @pandacss/dev@latest cssgen --cwd . --silent",
    "test": "pnpm inspect && pnpm build"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@pandacss/cli": "workspace:*",
    "@pandacss/vite": "workspace:*",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "typescript": "6.0.2",
    "vite": "7.2.6",
    "vite-tsconfig-paths": "5.1.4"
  }
}
