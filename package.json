{
  "name": "panda",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "The repository of css panda",
  "scripts": {
    "prepare": "husky && pnpm build:fast",
    "dev": "pnpm --parallel --filter=./packages/** dev",
    "build:fast": "pnpm -r --parallel --filter=./packages/** build:fast",
    "build": "pnpm --filter @pandacss/compiler-wasm build && pnpm -r --filter=./packages/** --filter=!@pandacss/compiler-wasm build",
    "bench:rust-spike": "pnpm --filter=./bench baseline",
    "bench:types": "pnpm --filter=./bench generated-types-perf",
    "rust:check": "cargo check --workspace --locked",
    "rust:test": "cargo nextest run --workspace --locked && pnpm rust:test:doc",
    "rust:test:cargo": "cargo test --workspace --locked",
    "rust:test:doc": "cargo test --workspace --doc --locked",
    "rust:fmt": "cargo fmt --all --check",
    "rust:clippy": "cargo clippy --workspace --all-targets --locked -- -D warnings",
    "check": "pnpm build && pnpm typecheck && pnpm lint && pnpm test run",
    "clean": "pnpm -r --parallel exec rimraf dist .turbo *.log",
    "reset": "pnpm -r --parallel exec rimraf node_modules && rimraf node_modules",
    "test": "vitest",
    "codegen": "pnpm --filter=./sandbox/codegen",
    "test:codegen": "pnpm codegen test && pnpm codegen typecheck",
    "test-watch": "vitest --watch -u",
    "lint": "eslint packages",
    "prettier": "prettier --check packages",
    "prettier-fix": "prettier --write packages",
    "typecheck": "tsc --noEmit",
    "release": "pnpm --filter @pandacss/compiler exec napi pre-publish --npm-dir npm --no-gh-release && changeset publish",
    "release-dev": "changeset version --snapshot dev && changeset publish --tag dev",
    "mdx-check": "mdx-local-link-checker docs && mdx-local-link-checker website/pages/docs"
  },
  "keywords": [],
  "author": "Segun Adebayo <joseshegs@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.29.8",
    "@projectwallace/format-css": "^2.0.0",
    "chokidar": "4.0.3",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "happy-dom": "20.0.11",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "mdx-local-link-checker": "2.1.1",
    "rimraf": "5.0.10",
    "ts-morph": "28.0.0",
    "tsup": "8.5.1",
    "tsx": "4.20.6",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/eslint": "9.6.1",
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.0.0",
    "prettier": "3.2.5",
    "typescript-eslint": "8.58.2",
    "vite-plugin-virtual": "^0.4.0"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "pnpm prettier-fix"
    ]
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "@swc/helpers@~0.4": "0.4.36",
      "picomatch@4.0.3": "4.0.4",
      "emnapi": "1.11.1",
      "@emnapi/core": "1.11.1",
      "@emnapi/runtime": "1.11.1"
    }
  }
}
